{
  "buildCommand": "npm ci && npm run build",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3",
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/(favicon\\.ico|robots\\.txt)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*\\.(?:css|js|map|png|jpg|jpeg|gif|svg|webp|ico|woff2?|ttf|eot))",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_EVENTS_CACHE": "/tmp/events.php",
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_ROUTES_CACHE": "/tmp/routes-v7.php",
    "APP_SERVICES_CACHE": "/tmp/services.php",
    "LARAVEL_STORAGE_PATH": "/tmp/storage",
    "SESSION_DRIVER": "cookie",
    "CACHE_STORE": "array",
    "LOG_CHANNEL": "stderr",
    "LOG_LEVEL": "error",
    "DB_SSLMODE": "require"
  }
}
